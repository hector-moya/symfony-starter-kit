{% extends 'base.html.twig' %}

{% block title %}Welcome — {{ app_name }}{% endblock %}

{% block body %}
<div class="container py-5">

    {# ── Hero ──────────────────────────────────── #}
    <div class="text-center mb-5">
        <div class="display-1 mb-3">⚡</div>
        <h1 class="display-4 fw-bold">{{ title }}</h1>
        <p class="lead text-muted">
            A modern Symfony 7 starter kit — production-ready, batteries included.
        </p>
        <div class="d-flex justify-content-center gap-3 mt-4">
            <a href="https://symfony.com/doc/current/index.html"
               class="btn btn-primary btn-lg" target="_blank" rel="noopener">
                📖 Symfony Docs
            </a>
            <a href="{{ path('app_login') }}" class="btn btn-outline-secondary btn-lg">
                🔑 Login
            </a>
        </div>
    </div>

    {# ── Feature Cards ──────────────────────────── #}
    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body p-4">
                    <div class="fs-1 mb-3">🗄️</div>
                    <h5 class="card-title fw-semibold">Doctrine ORM</h5>
                    <p class="card-text text-muted">
                        SQLite out of the box — zero config, works instantly.
                        Switch to MySQL or PostgreSQL by updating <code>DATABASE_URL</code>.
                    </p>
                    <code class="small text-muted">make migrate</code>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body p-4">
                    <div class="fs-1 mb-3">🔐</div>
                    <h5 class="card-title fw-semibold">Security Ready</h5>
                    <p class="card-text text-muted">
                        User entity with <code>UserInterface</code>, form-login firewall,
                        and password hashing pre-configured.
                    </p>
                    <code class="small text-muted">make controller</code>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body p-4">
                    <div class="fs-1 mb-3">⚡</div>
                    <h5 class="card-title fw-semibold">AssetMapper</h5>
                    <p class="card-text text-muted">
                        Bootstrap 5 + Alpine.js via native Symfony AssetMapper.
                        No webpack, no Node build step required.
                    </p>
                    <code class="small text-muted">assets/app.js</code>
                </div>
            </div>
        </div>
    </div>

    {# ── Quick Start ─────────────────────────────── #}
    <div class="card border-0 shadow-sm mb-5">
        <div class="card-body p-4">
            <h5 class="card-title fw-semibold mb-3">🚀 Quick Commands</h5>
            <div class="table-responsive">
                <table class="table table-sm table-striped mb-0">
                    <tbody>
                        <tr><td><code>make serve</code></td><td class="text-muted">Start the dev server</td></tr>
                        <tr><td><code>make entity</code></td><td class="text-muted">Create a new Doctrine entity</td></tr>
                        <tr><td><code>make controller</code></td><td class="text-muted">Create a new controller</td></tr>
                        <tr><td><code>make migrate</code></td><td class="text-muted">Run pending migrations</td></tr>
                        <tr><td><code>make fixtures</code></td><td class="text-muted">Reload seed data</td></tr>
                        <tr><td><code>make cache-clear</code></td><td class="text-muted">Clear the Symfony cache</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    {# ── Alpine.js demo ──────────────────────────── #}
    <div class="card border-0 shadow-sm" x-data="{ count: 0 }">
        <div class="card-body p-4 text-center">
            <h5 class="card-title fw-semibold mb-3">🏔️ Alpine.js is working</h5>
            <p class="text-muted mb-3">Counter: <strong x-text="count"></strong></p>
            <button class="btn btn-sm btn-outline-primary" @click="count++">Increment</button>
            <button class="btn btn-sm btn-outline-secondary ms-2" @click="count = 0">Reset</button>
        </div>
    </div>

</div>
{% endblock %}
