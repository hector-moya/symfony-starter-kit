APP_ENV=dev
APP_SECRET=changeme_run_setup_sh_to_generate
APP_SHARE_DIR=var/share

# Configure how to generate URLs in non-HTTP contexts (CLI commands, queues, etc.)
DEFAULT_URI=http://localhost

# Database
# SQLite (default — zero config, works instantly with Laravel Herd or plain PHP)
DATABASE_URL="sqlite:///%kernel.project_dir%/var/data.db"

# MySQL / MariaDB — uncomment and fill in to use instead
# DATABASE_URL="mysql://db_user:db_password@127.0.0.1:3306/db_name?serverVersion=8.0.32&charset=utf8mb4"

# PostgreSQL — uncomment and fill in to use instead
# DATABASE_URL="postgresql://db_user:db_password@127.0.0.1:5432/db_name?serverVersion=16&charset=utf8"

# Mailer
MAILER_DSN=null://null

# Messenger (async jobs) — optional, uncomment to enable
# MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
